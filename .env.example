# NanoClaw Configuration
# Copy to .env and fill in values

# --- Core ---
ANTHROPIC_API_KEY=
ASSISTANT_NAME=Odoo
TZ=Asia/Ho_Chi_Minh

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Container ---
CONTAINER_TIMEOUT=3600000
IDLE_TIMEOUT=3600000
MAX_CONCURRENT_CONTAINERS=2

# --- JIRA/Confluence (injected into containers via additionalEnvKeys) ---
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_SITE=https://newworldfashion.atlassian.net

# --- Test Server SSH (injected into containers via additionalEnvKeys) ---
SSH_TEST_HOST=192.168.1.243
SSH_TEST_PORT=2229
SSH_TEST_USER=root
SSH_TEST_PASS=
